{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "permission": {
    "bash": "deny"
  },
  "default_agent": "opentofu-dispatcher",
  "agent": {
    "build": {
      "mode": "primary",
      "disable": true
    },
    "plan": {
      "mode": "primary",
      "disable": true
    },
    "opentofu-dispatcher": {
      "mode": "primary",
      "permission": {
        "bash": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow"
      }
    },
    "opentofu-coding": {
      "mode": "primary",
      "permission": {
        "bash": {
          "*": "deny",
          "tofu fmt*": "allow",
          "tofu init*": "allow",
          "tofu validate*": "allow"
        },
        "read": "allow",
        "edit": "allow",
        "write": "allow",
        "glob": "allow",
        "grep": "allow"
      }
    },
    "opentofu-security": {
      "mode": "primary",
      "permission": {
        "bash": {
          "*": "deny",
          "checkov*": "allow",
          "trivy*": "allow"
        },
        "read": "allow",
        "glob": "allow",
        "grep": "allow"
      }
    },
    "aws-command-generator": {
      "mode": "primary",
      "permission": {
        "bash": "deny",
        "read": "allow",
        "glob": "allow"
      }
    }
  }
}
